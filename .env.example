# Copy this file to .env for local dev with `netlify dev`
# Never commit the real .env to your repo

# GitHub Personal Access Token
# Needs: repo (read + write contents) scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# GitHub repo in the format: username/repository
REPO=your-username/your-repo

# Path to data.json inside the repo (usually just "data.json")
FILE_PATH=data.json

# Secret token to protect the admin panel
# Choose any strong random string — you'll type this into the admin login screen
ADMIN_TOKEN=change_me_to_something_secret
